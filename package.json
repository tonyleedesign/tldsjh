{
  "name": "@make-kits/jh-ds",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./style.css": "./src/styles/themes.css"
  },
  "files": [
    "dist",
    "src/components",
    "src/styles/themes.css"
  ],
  "scripts": {
    "generate:tokens": "tsx src/tokens/buildCss.ts",
    "watch:tokens": "tsx --watch src/tokens/buildCss.ts",
    "dev": "concurrently \"vite\" \"tsx --watch src/tokens/buildCss.ts\"",
    "build": "vite build",
    "prebuild": "tsx src/tokens/buildCss.ts",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  }
}
